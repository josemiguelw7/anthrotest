# Neon Postgres (Vercel -> Storage -> Neon, or console.neon.tech). Pooled connection string.
DATABASE_URL=postgres://user:pass@ep-xxxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require
# Session signing secret — generate with: openssl rand -hex 32
AUTH_SECRET=change-me
# Server-only Anthropic key for the AI tutor
ANTHROPIC_API_KEY=sk-ant-...
# Optional: weekly report + password reset emails
RESEND_API_KEY=re_...
REPORT_FROM="AnthroTest <reports@anthrotest.com>"
CRON_SECRET=pick-a-random-string
# Optional access fencing for sign-ups (leave unset for open registration)
# ALLOWED_EMAIL_DOMAINS=goodleap.com,radtak.com
# INVITE_CODE=team-only-code
