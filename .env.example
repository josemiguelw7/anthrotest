# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://YOURPROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Server-only (never exposed to the browser)
SUPABASE_SERVICE_ROLE_KEY=eyJ...
